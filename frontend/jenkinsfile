pipeline {
    agent any

    environment {
        NODE_ENV = 'production'
    }

    stages {
        stage('Declarative: Checkout SCM') {
            steps {
                script {
                    checkout scm
                }
            }
        }

        stage('Clean and Install dependencies') {
            steps {
                script {
                    // Assurer une installation propre des modules Node
                    dir('frontend') {
                        sh 'rm -rf node_modules'
                        sh 'npm ci --legacy-peer-deps'
                    }
                }
            }
        }

        stage('Unit Test') {
            steps {
                script {
                    // Exécuter les tests en passant à l'étape suivante si aucun test n'est trouvé
                    dir('frontend') {
                        sh 'npm test -- --passWithNoTests'
                    }
                }
            }
        }

        stage('Build application') {
            steps {
                script {
                    dir('frontend') {
                        sh 'npm run build'
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    echo 'Déploiement de l\'application'
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline terminé.'
        }
        success {
            echo 'Le pipeline a réussi !'
        }
        failure {
            echo 'Le pipeline a échoué.'
        }
    }
}

pipeline {
    agent any

    environment {
        NODE_ENV = 'production'
        SKIP_TESTS = 'true' // Changer cette valeur pour passer ou ignorer les tests
    }

    stages {
        stage('Declarative: Checkout SCM') {
            steps {
                script {
                    checkout scm
                }
            }
        }

        stage('Clean and Install dependencies') {
            steps {
                script {
                    dir('frontend') {
                        sh 'rm -rf node_modules'
                        sh 'npm ci --legacy-peer-deps'
                    }
                }
            }
        }

        stage('Unit Test') {
            when {
                expression { return env.SKIP_TESTS != 'true' }
            }
            steps {
                script {
                    dir('frontend') {
                        sh 'npm test -- --passWithNoTests'
                    }
                }
            }
        }

        stage('Build application') {
            steps {
                script {
                    dir('frontend') {
                        sh 'npm run build'
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    echo 'Déploiement de l\'application'
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline terminé.'
        }
        success {
            echo 'Le pipeline a réussi !'
        }
        failure {
            echo 'Le pipeline a échoué.'
        }
    }
}

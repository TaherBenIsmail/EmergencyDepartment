pipeline {
    agent any

    stages {
        stage('Install dependencies') {
            steps {
                script {
                    // Installer les dépendances
                    dir('frontend') {
                        sh 'npm install'
                    }
                }
            }
        }

        stage('Unit Test') {
            steps {
                script {
                    // Exécuter les tests avec l'option --passWithNoTests pour ne pas échouer si aucun test n'est trouvé
                    dir('frontend') {
                        sh 'npm test -- --passWithNoTests'
                    }
                }
            }
        }

        stage('Build application') {
            steps {
                script {
                    // Construction de l'application
                    dir('frontend') {
                        sh 'npm run build'
                    }
                }
            }
        }
    }
}

pipeline {
    agent any

    stages {
        stage('Install dependencies') {
            steps {
                script {
                    dir('frontend') {  // Se déplacer dans le répertoire frontend
                        sh 'npm install'
                    }
                }
            }
        }

        stage('Unit Test') {
            steps {
                script {
                    dir('frontend') {  // Se déplacer dans le répertoire frontend
                        sh 'npm test'
                    }
                }
            }
        }

        stage('Build application') {
            steps {
                script {
                    dir('frontend') {  // Se déplacer dans le répertoire frontend
                        sh 'npm run build-dev'
                    }
                }
            }
        }
    }
}

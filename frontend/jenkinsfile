pipeline {
    agent any

    environment {
        // Définir les variables d'environnement si nécessaire
        NODE_ENV = 'production'
    }

    stages {
        stage('Declarative: Checkout SCM') {
            steps {
                script {
                    // Effectue le checkout du code source
                    checkout scm
                }
            }
        }

        stage('Install dependencies') {
            steps {
                script {
                    // Installer les dépendances du projet Node.js (frontend)
                    dir('frontend') {
                        sh 'npm install'
                    }
                }
            }
        }

        stage('Unit Test') {
            steps {
                script {
                    // Exécute les tests en ignorant les erreurs si aucun test n'est trouvé
                    dir('frontend') {
                        sh 'npm test -- --passWithNoTests'
                    }
                }
            }
        }

        stage('Build application') {
            steps {
                script {
                    // Construire l'application avec Next.js
                    dir('frontend') {
                        sh 'npm run build'
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    // Ajouter ici les étapes de déploiement si nécessaires
                    echo 'Déploiement de l\'application'
                }
            }
        }
    }

    post {
        always {
            // Nettoyage ou actions à faire après chaque exécution
            echo 'Pipeline terminé.'
        }
        success {
            echo 'Le pipeline a réussi !'
        }
        failure {
            echo 'Le pipeline a échoué.'
        }
    }
}
